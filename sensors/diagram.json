    [ "sensor_a:2.l", "esp32:GND.1",   "black", [] ],
    [ "sensor_b:2.l", "esp32:GND.1",   "black", [] ],
    [ "led_green:C",  "esp32:GND.2",   "black", [] ],
    [ "led_amber:C",  "esp32:GND.2",   "black", [] ],
    [ "led_red:C",    "esp32:GND.2",   "black", [] ],
    [ "lcd:GND",      "esp32:GND.2",   "black", [] ]
